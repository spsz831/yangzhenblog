---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { Button } from "@/components/ui/button";
import { Card, CardHeader, CardTitle, CardContent, CardDescription } from "@/components/ui/card";
import { PlusCircle, FileText, Tags, Image as ImageIcon, BarChart, Upload, PenTool, ExternalLink } from "lucide-react";
import { getDb } from "@/db";
import { posts, publishRuns, tags } from "@/db/schema";
import { count, desc, eq } from "drizzle-orm";
import { format } from "date-fns";
import FormAlert from "@/components/admin/FormAlert.astro";

export const prerender = false;

const db = getDb(Astro.locals.runtime.env.DB);
const bucket = Astro.locals.runtime.env.BUCKET;
const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const countParam = Astro.url.searchParams.get("count");
const manualRunCount = countParam ? Number.parseInt(countParam, 10) : null;
const publishingSuccess =
  success === "publishing_run"
    ? `发布检查已执行，本次共发布 ${Number.isNaN(manualRunCount ?? NaN) ? 0 : manualRunCount} 篇文章。`
    : null;
const publishingError = error;

// Fetch stats
const [{ value: totalPosts }] = await db.select({ value: count() }).from(posts);
const [{ value: publishedPosts }] = await db.select({ value: count() }).from(posts).where(eq(posts.status, 'published'));
const [{ value: draftPosts }] = await db.select({ value: count() }).from(posts).where(eq(posts.status, 'draft'));
const [{ value: scheduledPosts }] = await db.select({ value: count() }).from(posts).where(eq(posts.status, 'scheduled'));
const [{ value: totalTags }] = await db.select({ value: count() }).from(tags);

// Fetch images count
let totalImages = 0;
try {
  const list = await bucket.list();
  totalImages = list.objects.length;
} catch (e) {
  console.error("Failed to list images", e);
}

// Fetch recent posts
const recentPosts = await db.select().from(posts).orderBy(desc(posts.updatedAt)).limit(5);
const recentPublishRuns = await db.select().from(publishRuns).orderBy(desc(publishRuns.createdAt)).limit(8);

const formatTriggerType = (triggerType: string) => {
  if (triggerType === "cron") return "定时任务";
  if (triggerType === "manual") return "手动执行";
  return "请求兜底";
};

const formatRunStatus = (status: string) => (status === "failed" ? "失败" : "成功");
---

<AdminLayout title="仪表盘">
  <FormAlert error={publishingError} />
  <FormAlert success={publishingSuccess} />
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-3xl font-bold tracking-tight">仪表盘</h2>
    <div class="flex items-center space-x-2">
      <Button asChild>
        <a href="/admin/posts/new">
          <PlusCircle className="mr-2 h-4 w-4" />
          发布文章
        </a>
      </Button>
    </div>
  </div>

  <!-- Data Cards -->
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-8">
    <Card>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
        <CardTitle className="text-sm font-medium">文章总数</CardTitle>
        <FileText className="h-4 w-4 text-muted-foreground" />
      </CardHeader>
      <CardContent>
        <div class="text-2xl font-bold">{totalPosts}</div>
        <p class="text-xs text-muted-foreground">
          {publishedPosts} 已发布 · {draftPosts} 草稿 · {scheduledPosts} 定时
        </p>
      </CardContent>
    </Card>
    <Card>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
        <CardTitle className="text-sm font-medium">标签总数</CardTitle>
        <Tags className="h-4 w-4 text-muted-foreground" />
      </CardHeader>
      <CardContent>
        <div class="text-2xl font-bold">{totalTags}</div>
        <p class="text-xs text-muted-foreground">
          用于分类和检索
        </p>
      </CardContent>
    </Card>
    <Card>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
        <CardTitle className="text-sm font-medium">图片总数</CardTitle>
        <ImageIcon className="h-4 w-4 text-muted-foreground" />
      </CardHeader>
      <CardContent>
        <div class="text-2xl font-bold">{totalImages}</div>
        <p class="text-xs text-muted-foreground">
          存储在 R2 Bucket
        </p>
      </CardContent>
    </Card>
    <Card>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
        <CardTitle className="text-sm font-medium">站点状态</CardTitle>
        <BarChart className="h-4 w-4 text-muted-foreground" />
      </CardHeader>
      <CardContent>
        <div class="text-2xl font-bold">运行中</div>
        <p class="text-xs text-muted-foreground">
          Cloudflare Pages
        </p>
      </CardContent>
    </Card>
  </div>

  <div class="grid gap-4 lg:grid-cols-[minmax(0,1.3fr)_minmax(300px,0.7fr)] mb-8">
    <Card>
      <CardHeader className="flex flex-row items-start justify-between gap-4">
        <div>
          <CardTitle>发布任务状态</CardTitle>
          <CardDescription>
            自动 cron 每分钟检查一次，你也可以在这里手动补跑发布检查。
          </CardDescription>
        </div>
        <form action="/api/admin/publishing/run" method="POST">
          <Button type="submit" variant="outline">立即执行检查</Button>
        </form>
      </CardHeader>
      <CardContent className="grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-border/70 bg-muted/20 px-4 py-4">
          <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Cron 频率</p>
          <p class="mt-2 text-xl font-semibold">每分钟</p>
          <p class="mt-1 text-xs text-muted-foreground">当前配置 `* * * * *`</p>
        </div>
        <div class="rounded-2xl border border-border/70 bg-muted/20 px-4 py-4">
          <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">待发布文章</p>
          <p class="mt-2 text-xl font-semibold">{scheduledPosts}</p>
          <p class="mt-1 text-xs text-muted-foreground">处于 scheduled 状态的文章数量</p>
        </div>
        <div class="rounded-2xl border border-border/70 bg-muted/20 px-4 py-4">
          <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">最近执行</p>
          <p class="mt-2 text-xl font-semibold">
            {recentPublishRuns[0]?.createdAt ? format(recentPublishRuns[0].createdAt, "MM-dd HH:mm") : "暂无"}
          </p>
          <p class="mt-1 text-xs text-muted-foreground">
            {recentPublishRuns[0]
              ? `${formatTriggerType(recentPublishRuns[0].triggerType)} · ${formatRunStatus(recentPublishRuns[0].status)} · ${recentPublishRuns[0].durationMs ?? 0}ms`
              : "尚未记录发布任务"}
          </p>
        </div>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>最近发布记录</CardTitle>
        <CardDescription>
          展示自动任务、手动执行和兜底发布的最近日志。
        </CardDescription>
      </CardHeader>
      <CardContent>
        <div class="space-y-4">
          {recentPublishRuns.map((run) => (
            <div class="rounded-2xl border border-border/70 px-4 py-3">
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-2">
                  <p class="text-sm font-medium">{formatTriggerType(run.triggerType)}</p>
                  <span class:list={[
                    "inline-flex rounded-full px-2 py-0.5 text-[11px] font-medium",
                    run.status === "failed"
                      ? "bg-destructive/10 text-destructive"
                      : "bg-emerald-500/10 text-emerald-700 dark:text-emerald-300",
                  ]}>
                    {formatRunStatus(run.status)}
                  </span>
                </div>
                <p class="text-xs text-muted-foreground">
                  {run.createdAt ? format(run.createdAt, "yyyy-MM-dd HH:mm:ss") : "无时间"}
                </p>
              </div>
              <p class="mt-2 text-sm text-muted-foreground">
                发布 {run.publishedCount} 篇
                {run.triggerLabel ? ` · ${run.triggerLabel}` : ""}
                {typeof run.durationMs === "number" ? ` · ${run.durationMs}ms` : ""}
              </p>
              {run.errorMessage && (
                <p class="mt-2 rounded-xl border border-destructive/20 bg-destructive/5 px-3 py-2 text-xs text-destructive break-all">
                  错误：{run.errorMessage}
                </p>
              )}
              <p class="mt-1 text-xs text-muted-foreground break-all">
                {run.publishedSlugs ? `Slug: ${run.publishedSlugs}` : "本次没有到点可发布的文章。"}
              </p>
            </div>
          ))}
          {recentPublishRuns.length === 0 && (
            <p class="text-sm text-muted-foreground">还没有发布任务记录。</p>
          )}
        </div>
      </CardContent>
    </Card>
  </div>

  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-7">
    <!-- Recent Activity -->
    <Card className="col-span-4">
      <CardHeader>
        <CardTitle>最近动态</CardTitle>
        <CardDescription>
          最近编辑或发布的 5 篇文章
        </CardDescription>
      </CardHeader>
      <CardContent>
        <div class="space-y-8">
          {recentPosts.map((post) => (
            <div class="flex items-center">
              <div class="space-y-1">
                <p class="text-sm font-medium leading-none">
                  <a href={`/admin/posts/${post.id}/edit`} class="hover:underline">
                    {post.title}
                  </a>
                </p>
                <p class="text-xs text-muted-foreground">
                  {post.status === 'published' ? '已发布' : post.status === 'scheduled' ? '定时发布' : '草稿'} · {post.updatedAt ? format(post.updatedAt, "yyyy-MM-dd HH:mm") : "无时间"}
                </p>
              </div>
              <div class="ml-auto font-medium text-sm">
                <a href={`/admin/posts/${post.id}/edit`} class="text-muted-foreground hover:text-primary">
                  编辑
                </a>
              </div>
            </div>
          ))}
          {recentPosts.length === 0 && (
            <p class="text-sm text-muted-foreground">暂无文章动态</p>
          )}
        </div>
      </CardContent>
    </Card>

    <!-- Quick Actions -->
    <Card className="col-span-3">
      <CardHeader>
        <CardTitle>快捷操作</CardTitle>
        <CardDescription>
          常用功能快速入口
        </CardDescription>
      </CardHeader>
      <CardContent className="grid gap-4">
        <Button variant="outline" className="w-full justify-start" asChild>
          <a href="/admin/images">
            <Upload className="mr-2 h-4 w-4" />
            上传图片
          </a>
        </Button>
        <Button variant="outline" className="w-full justify-start" asChild>
          <a href="/admin/posts/new">
            <PenTool className="mr-2 h-4 w-4" />
            写新文章
          </a>
        </Button>
        <Button variant="outline" className="w-full justify-start" asChild>
          <a href="/" target="_blank">
            <ExternalLink className="mr-2 h-4 w-4" />
            查看站点
          </a>
        </Button>
      </CardContent>
    </Card>
  </div>
</AdminLayout>

