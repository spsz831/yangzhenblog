---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDb } from "@/db";
import { posts, tags, postsToTags } from "@/db/schema";
import { eq } from "drizzle-orm";
import { Button } from "@/components/ui/button";
import FormAlert from "@/components/admin/FormAlert.astro";
import PostEditorForm from "@/components/admin/PostEditorForm.astro";

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/posts");
const error = Astro.url.searchParams.get("error");

const db = getDb(Astro.locals.runtime.env.DB);
const post = await db.select().from(posts).where(eq(posts.id, Number(id))).get();

if (!post) return Astro.redirect("/admin/posts");

const postTags = await db.select({ name: tags.name })
  .from(tags)
  .innerJoin(postsToTags, eq(tags.id, postsToTags.tagId))
  .where(eq(postsToTags.postId, post.id))
  .all();

const tagsString = postTags.map(t => t.name).join(", ");
---

<AdminLayout title="Edit Post">
  <div class="max-w-2xl mx-auto">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold tracking-tight">编辑文章</h2>
      <form action={`/api/posts/${post.id}/delete`} method="POST" onsubmit="return confirm('确定要删除这篇文章吗？');">
        <Button variant="destructive" type="submit">删除文章</Button>
      </form>
    </div>
    <FormAlert error={error} />
    
    <PostEditorForm
      action={`/api/posts/${post.id}`}
      cancelHref="/admin/posts"
      submitLabel="保存修改"
      autosaveKey={`admin-post-edit-${post.id}`}
      tags={tagsString}
      values={post}
    />
  </div>
</AdminLayout>
