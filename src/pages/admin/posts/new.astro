---
import AdminLayout from "@/layouts/AdminLayout.astro";
import FormAlert from "@/components/admin/FormAlert.astro";
import PostEditorForm from "@/components/admin/PostEditorForm.astro";
import { findNextNumericSlug } from "@/lib/admin-posts";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
const suggestedSlug = await findNextNumericSlug({ locals: Astro.locals });
---

<AdminLayout title="New Post">
  <div class="mx-auto w-full max-w-[1700px]">
    <h2 class="text-2xl font-bold tracking-tight mb-6">新建文章</h2>
    <FormAlert error={error} />
    <PostEditorForm
      action="/api/posts"
      cancelHref="/admin/posts"
      submitLabel="创建文章"
      autosaveKey="admin-post-new-draft"
      suggestedSlug={suggestedSlug}
    />
  </div>
</AdminLayout>
