---
import "@/styles/global.css";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Label } from "@/components/ui/label";
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>管理员登录 - 杨振博客</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-[#f7f4ee] px-4 py-6 text-zinc-900 antialiased sm:px-6 lg:px-8">
    <div class="pointer-events-none absolute inset-0 opacity-30 [background-image:linear-gradient(rgba(24,24,27,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(24,24,27,0.025)_1px,transparent_1px)] [background-size:44px_44px]"></div>
    <div class="pointer-events-none absolute inset-x-0 top-0 h-[28rem] bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.96),transparent_70%)]"></div>

    <main class="relative mx-auto flex min-h-[calc(100vh-3rem)] w-full max-w-3xl items-center justify-center">
      <div class="flex w-full justify-center rounded-[40px] border border-black/5 bg-white/42 p-4 shadow-[0_28px_90px_rgba(15,23,42,0.05)] backdrop-blur-xl sm:p-5">
        <div class="relative w-full max-w-[440px]">
          <div class="pointer-events-none absolute left-1/2 top-1/2 h-[86%] w-[86%] -translate-x-1/2 -translate-y-1/2 rounded-[40px] bg-white/82 shadow-[0_28px_90px_rgba(15,23,42,0.10)] blur-2xl"></div>
          <Card className="relative w-full rounded-[36px] border border-black/6 bg-[#fffdfa]/98 shadow-[0_22px_70px_rgba(15,23,42,0.07)] backdrop-blur-xl">
            <CardHeader className="space-y-6 px-8 pb-4 pt-8 sm:px-10">
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-black/7 bg-[#fbfaf7] text-zinc-900 shadow-[0_8px_24px_rgba(15,23,42,0.05)]">
                  <span class="i-lucide-feather text-lg"></span>
                </span>
                <div class="leading-none">
                  <p class="font-['Georgia','Times_New_Roman',serif] text-base text-zinc-950">杨振博客</p>
                  <p class="mt-1 text-[11px] uppercase tracking-[0.24em] text-zinc-500">Admin Console</p>
                </div>
              </div>

              <div class="space-y-3 pt-4">
                <CardTitle className="font-['Georgia','Times_New_Roman',serif] text-[32px] font-medium tracking-[-0.04em] text-zinc-950">
                  继续登录
                </CardTitle>
                <CardDescription className="max-w-md text-[14px] leading-7 text-zinc-600">
                  输入当前用户名或邮箱，以及对应密码。
                </CardDescription>
              </div>
            </CardHeader>

            <form action="/api/auth/login" method="POST">
              <CardContent className="space-y-6 px-8 pb-4 sm:px-10">
                {error === "invalid_credentials" && (
                  <div class="rounded-[20px] border border-red-200 bg-red-50/90 px-4 py-3 text-sm leading-6 text-red-600">
                    当前登录标识或密码不正确，请确认你使用的是最新的用户名、邮箱和密码。
                  </div>
                )}
                {error === "missing_fields" && (
                  <div class="rounded-[20px] border border-red-200 bg-red-50/90 px-4 py-3 text-sm leading-6 text-red-600">
                    请填写完整的登录信息后再提交。
                  </div>
                )}

                <div class="space-y-3">
                  <Label htmlFor="email" className="text-[12px] font-medium uppercase tracking-[0.22em] text-zinc-500">
                    邮箱或用户名
                  </Label>
                  <Input
                    id="email"
                    name="email"
                    type="text"
                    placeholder="请输入当前邮箱或用户名"
                    autocomplete="username"
                    required
                    className="h-13 rounded-[20px] border-black/10 bg-[#f8f6f1] px-4 text-[15px] shadow-none transition focus-visible:border-zinc-900/30 focus-visible:ring-zinc-900/10"
                  />
                </div>

                <div class="space-y-3">
                  <Label htmlFor="password" className="text-[12px] font-medium uppercase tracking-[0.22em] text-zinc-500">
                    密码
                  </Label>
                  <Input
                    id="password"
                    name="password"
                    type="password"
                    placeholder="请输入密码"
                    autocomplete="current-password"
                    required
                    className="h-13 rounded-[20px] border-black/10 bg-[#f8f6f1] px-4 text-[15px] shadow-none transition focus-visible:border-zinc-900/30 focus-visible:ring-zinc-900/10"
                  />
                </div>
              </CardContent>

              <CardFooter className="flex-col items-stretch gap-4 px-8 pb-8 pt-3 sm:px-10">
                <Button
                  type="submit"
                  className="h-13 rounded-[20px] bg-zinc-950 text-sm font-medium tracking-[0.03em] text-white shadow-[0_20px_44px_rgba(24,24,27,0.16)] transition hover:bg-zinc-800"
                >
                  登录后台
                </Button>
                <div class="flex items-center justify-between gap-3 text-[11px] text-zinc-400">
                  <span>Private access</span>
                  <span>Yangzhen Blog</span>
                </div>
              </CardFooter>
            </form>
          </Card>
        </div>
      </div>
    </main>
  </body>
</html>
