---
import "@/styles/global.css";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Label } from "@/components/ui/label";
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>管理员登录 - 杨振博客</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-[#f4f1ea] px-4 py-6 text-zinc-900 antialiased">
    <div class="pointer-events-none absolute inset-0 opacity-45 [background-image:linear-gradient(rgba(24,24,27,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(24,24,27,0.03)_1px,transparent_1px)] [background-size:36px_36px]"></div>
    <div class="pointer-events-none absolute inset-x-0 top-0 h-80 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.92),transparent_70%)]"></div>

    <main class="relative mx-auto flex min-h-[calc(100vh-3rem)] w-full max-w-7xl items-center justify-center">
      <div class="grid w-full items-center gap-8 rounded-[40px] border border-black/6 bg-white/42 px-5 py-6 shadow-[0_30px_120px_rgba(15,23,42,0.08)] backdrop-blur-xl lg:grid-cols-[minmax(0,1.15fr)_460px] lg:px-8 lg:py-8">
        <section class="rounded-[32px] bg-white/58 px-6 py-7 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] lg:px-9 lg:py-10">
          <div class="inline-flex items-center gap-3 rounded-full border border-black/8 bg-white/78 px-4 py-2 shadow-[0_1px_2px_rgba(0,0,0,0.04)]">
            <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-black/8 bg-[#fbfaf7] text-zinc-900 shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
              <span class="i-lucide-feather text-lg"></span>
            </span>
            <div class="leading-none">
              <p class="font-['Georgia','Times_New_Roman',serif] text-[15px] tracking-[0.02em] text-zinc-950">杨振博客</p>
              <p class="mt-1 text-[11px] uppercase tracking-[0.26em] text-zinc-500">Editorial Console</p>
            </div>
          </div>

          <div class="mt-10 max-w-3xl">
            <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">Private Workspace</p>
            <h1 class="mt-5 max-w-2xl font-['Georgia','Times_New_Roman',serif] text-4xl font-medium leading-[1.04] tracking-[-0.04em] text-zinc-950 md:text-5xl xl:text-6xl">
              进入你的写作后台，
              <br />
              像翻开一本安静的手稿。
            </h1>
            <p class="mt-6 max-w-2xl text-[16px] leading-8 text-zinc-600 md:text-[17px]">
              这里是属于你的内容工作台。登录后继续管理文章、资料、图片与发布节奏，让博客后台像创作空间一样自然，而不是冰冷的系统入口。
            </p>
          </div>

          <div class="mt-10 grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
            <div class="rounded-[28px] border border-black/7 bg-[#fcfbf8]/92 p-6 shadow-[0_18px_48px_rgba(15,23,42,0.05)]">
              <p class="text-xs uppercase tracking-[0.22em] text-zinc-500">Publishing</p>
              <p class="mt-4 font-['Georgia','Times_New_Roman',serif] text-[28px] leading-tight text-zinc-950">
                发布与修订
              </p>
              <p class="mt-3 text-[14px] leading-7 text-zinc-600">
                新建文章时会自动建议下一个编号，并在提交前检查 slug 冲突，减少发文时的试错和回滚。
              </p>
            </div>

            <div class="rounded-[28px] border border-black/7 bg-[#fcfbf8]/92 p-6 shadow-[0_18px_48px_rgba(15,23,42,0.05)]">
              <p class="text-xs uppercase tracking-[0.22em] text-zinc-500">Security</p>
              <p class="mt-4 font-['Georgia','Times_New_Roman',serif] text-[28px] leading-tight text-zinc-950">
                会话与保护
              </p>
              <p class="mt-3 text-[14px] leading-7 text-zinc-600">
                后台已切换为数据库 session 模型，登录、退出与改密都会同步清理会话，行为更接近正式生产环境。
              </p>
            </div>
          </div>
        </section>

        <div class="relative">
          <div class="pointer-events-none absolute inset-0 rounded-[36px] bg-white/70 shadow-[0_35px_120px_rgba(15,23,42,0.12)] blur-2xl"></div>
          <Card className="relative w-full rounded-[34px] border border-black/7 bg-[#fffdfa]/94 shadow-[0_28px_90px_rgba(15,23,42,0.10)] backdrop-blur-xl">
            <CardHeader className="space-y-6 px-8 pb-4 pt-8 sm:px-10">
              <div class="flex items-center gap-3 lg:hidden">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-black/8 bg-[#fbfaf7] text-zinc-900 shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
                  <span class="i-lucide-feather text-lg"></span>
                </span>
                <div class="leading-none">
                  <p class="font-['Georgia','Times_New_Roman',serif] text-base text-zinc-950">杨振博客</p>
                  <p class="mt-1 text-[11px] uppercase tracking-[0.26em] text-zinc-500">Editorial Console</p>
                </div>
              </div>

              <div class="space-y-3">
                <CardTitle className="font-['Georgia','Times_New_Roman',serif] text-[34px] font-medium tracking-[-0.04em] text-zinc-950">
                  欢迎回来
                </CardTitle>
                <CardDescription className="max-w-md text-[15px] leading-7 text-zinc-600">
                  使用你当前的用户名或邮箱进入后台，继续管理博客内容与账号设置。
                </CardDescription>
              </div>
            </CardHeader>

            <form action="/api/auth/login" method="POST">
              <CardContent className="space-y-6 px-8 pb-4 sm:px-10">
                {error === "invalid_credentials" && (
                  <div class="rounded-[20px] border border-red-200 bg-red-50/90 px-4 py-3 text-sm leading-6 text-red-600">
                    当前登录标识或密码不正确，请确认你使用的是最新的用户名、邮箱和密码。
                  </div>
                )}
                {error === "missing_fields" && (
                  <div class="rounded-[20px] border border-red-200 bg-red-50/90 px-4 py-3 text-sm leading-6 text-red-600">
                    请填写完整的登录信息后再提交。
                  </div>
                )}

                <div class="space-y-3">
                  <Label htmlFor="email" className="text-[12px] font-medium uppercase tracking-[0.22em] text-zinc-500">
                    邮箱或用户名
                  </Label>
                  <Input
                    id="email"
                    name="email"
                    type="text"
                    placeholder="请输入当前邮箱或用户名"
                    autocomplete="username"
                    required
                    className="h-13 rounded-[20px] border-black/10 bg-[#f8f6f1] px-4 text-[15px] shadow-none transition focus-visible:border-zinc-900/30 focus-visible:ring-zinc-900/10"
                  />
                </div>

                <div class="space-y-3">
                  <Label htmlFor="password" className="text-[12px] font-medium uppercase tracking-[0.22em] text-zinc-500">
                    密码
                  </Label>
                  <Input
                    id="password"
                    name="password"
                    type="password"
                    placeholder="请输入密码"
                    autocomplete="current-password"
                    required
                    className="h-13 rounded-[20px] border-black/10 bg-[#f8f6f1] px-4 text-[15px] shadow-none transition focus-visible:border-zinc-900/30 focus-visible:ring-zinc-900/10"
                  />
                </div>
              </CardContent>

              <CardFooter className="flex-col items-stretch gap-5 px-8 pb-8 pt-3 sm:px-10">
                <Button
                  type="submit"
                  className="h-13 rounded-[20px] bg-zinc-950 text-sm font-medium tracking-[0.03em] text-white shadow-[0_20px_44px_rgba(24,24,27,0.16)] transition hover:bg-zinc-800"
                >
                  登录后台
                </Button>
                <div class="flex items-center justify-between gap-4 text-xs text-zinc-500">
                  <span>受保护的内容工作台入口</span>
                  <span>Session secured</span>
                </div>
              </CardFooter>
            </form>
          </Card>
        </div>
      </div>
    </main>
  </body>
</html>
