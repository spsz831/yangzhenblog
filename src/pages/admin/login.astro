---
import "@/styles/global.css";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Label } from "@/components/ui/label";
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>管理员登录 - 杨振博客</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-[#f5f5f7] text-zinc-900 antialiased">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.98),transparent_38%),radial-gradient(circle_at_bottom,rgba(255,255,255,0.72),transparent_42%)]"></div>
    <div class="pointer-events-none absolute inset-0 opacity-[0.14] [background-image:linear-gradient(rgba(29,29,31,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(29,29,31,0.05)_1px,transparent_1px)] [background-size:56px_56px]"></div>

    <main class="relative flex min-h-screen items-center justify-center px-6 py-10 sm:px-10 lg:px-16">
      <div class="w-full max-w-6xl">
        <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] lg:gap-20">
          <section class="mx-auto flex max-w-[34rem] flex-col text-center lg:mx-0 lg:text-left">
            <div class="mx-auto flex w-fit items-center gap-3 rounded-full border border-black/8 bg-white/82 px-4 py-2 shadow-[0_8px_24px_rgba(15,23,42,0.04)] backdrop-blur-sm lg:mx-0">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-zinc-950 shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
                <span class="i-lucide-feather text-lg"></span>
              </span>
              <div class="leading-none">
                <p class="text-[15px] font-semibold tracking-[-0.02em] text-zinc-950">杨振博客</p>
                <p class="mt-1 text-[11px] uppercase tracking-[0.24em] text-zinc-500">Admin Console</p>
              </div>
            </div>

            <div class="mt-12 lg:mt-16">
              <p class="text-[12px] uppercase tracking-[0.3em] text-zinc-500">Yangzhen Blog Admin</p>
              <h1 class="mt-5 text-[42px] font-semibold leading-[1.02] tracking-[-0.055em] text-zinc-950 sm:text-[54px] lg:text-[64px] xl:text-[72px]">
                进入后台，
                <br />
                保持清晰与安静。
              </h1>
            </div>

            <p class="mx-auto mt-8 max-w-xl text-[17px] leading-8 tracking-[-0.01em] text-zinc-600 lg:mx-0 lg:text-[18px]">
              使用当前用户名或邮箱登录，进入文章、媒体资源与账号设置。
            </p>

            <div class="mt-10 flex flex-wrap justify-center gap-3 lg:justify-start">
              <span class="rounded-full bg-white px-4 py-2 text-[13px] text-zinc-600 shadow-[0_8px_24px_rgba(15,23,42,0.05)]">文章管理</span>
              <span class="rounded-full bg-white px-4 py-2 text-[13px] text-zinc-600 shadow-[0_8px_24px_rgba(15,23,42,0.05)]">媒体资源</span>
              <span class="rounded-full bg-white px-4 py-2 text-[13px] text-zinc-600 shadow-[0_8px_24px_rgba(15,23,42,0.05)]">账号设置</span>
            </div>
          </section>

          <section class="relative">
            <div class="pointer-events-none absolute left-1/2 top-1/2 h-[88%] w-full max-w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-[44px] bg-white/80 blur-3xl"></div>
            <Card className="relative mx-auto w-full max-w-[520px] rounded-[44px] border border-white/80 bg-white/84 shadow-[0_36px_100px_rgba(15,23,42,0.12)] backdrop-blur-2xl">
            <CardHeader className="space-y-6 px-8 pb-4 pt-8 sm:px-10">
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-zinc-950 text-white shadow-[0_8px_24px_rgba(15,23,42,0.16)]">
                  <span class="i-lucide-feather text-lg"></span>
                </span>
                <div class="leading-none">
                  <p class="text-base font-semibold tracking-[-0.02em] text-zinc-950">管理后台</p>
                  <p class="mt-1 text-[11px] uppercase tracking-[0.24em] text-zinc-500">Sign in</p>
                </div>
              </div>

              <div class="space-y-3 pt-5">
                <CardTitle className="text-[36px] font-semibold tracking-[-0.055em] text-zinc-950 sm:text-[42px]">
                  继续登录
                </CardTitle>
                <CardDescription className="max-w-md text-[15px] leading-7 text-zinc-600 sm:text-[16px]">
                  输入当前用户名或邮箱，以及对应密码。
                </CardDescription>
              </div>
            </CardHeader>

            <form action="/api/auth/login" method="POST">
              <CardContent className="space-y-7 px-8 pb-4 sm:px-10">
                {error === "invalid_credentials" && (
                  <div class="rounded-[20px] border border-red-200 bg-red-50/90 px-4 py-3 text-sm leading-6 text-red-600">
                    当前登录标识或密码不正确，请确认你使用的是最新的用户名、邮箱和密码。
                  </div>
                )}
                {error === "missing_fields" && (
                  <div class="rounded-[20px] border border-red-200 bg-red-50/90 px-4 py-3 text-sm leading-6 text-red-600">
                    请填写完整的登录信息后再提交。
                  </div>
                )}

                <div class="space-y-3">
                  <Label htmlFor="email" className="text-[12px] font-medium uppercase tracking-[0.22em] text-zinc-500">
                    邮箱或用户名
                  </Label>
                  <Input
                    id="email"
                    name="email"
                    type="text"
                    placeholder="请输入当前邮箱或用户名"
                    autocomplete="username"
                    required
                    className="h-14 rounded-[20px] border-black/10 bg-white/92 px-5 text-[15px] shadow-none transition focus-visible:border-[#0071e3] focus-visible:ring-[#0071e3]/15"
                  />
                </div>

                <div class="space-y-3">
                  <Label htmlFor="password" className="text-[12px] font-medium uppercase tracking-[0.22em] text-zinc-500">
                    密码
                  </Label>
                  <Input
                    id="password"
                    name="password"
                    type="password"
                    placeholder="请输入密码"
                    autocomplete="current-password"
                    required
                    className="h-14 rounded-[20px] border-black/10 bg-white/92 px-5 text-[15px] shadow-none transition focus-visible:border-[#0071e3] focus-visible:ring-[#0071e3]/15"
                  />
                </div>
              </CardContent>

              <CardFooter className="flex-col items-stretch gap-5 px-8 pb-8 pt-4 sm:px-10">
                <Button
                  type="submit"
                  className="h-14 rounded-full bg-[#0071e3] text-[15px] font-medium text-white shadow-[0_20px_44px_rgba(0,113,227,0.3)] transition hover:bg-[#0066cc]"
                >
                  登录后台
                </Button>
                <div class="flex items-center justify-between gap-3 text-[11px] text-zinc-400">
                  <span>仅限后台管理使用</span>
                  <span>Yangzhen Blog</span>
                </div>
              </CardFooter>
            </form>
            </Card>
          </section>
        </div>
      </div>
    </main>
  </body>
</html>
